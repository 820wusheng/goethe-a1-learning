<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Goethe A1 完整考试练习</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        h1 {
            color: #667eea;
            text-align: center;
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 1.1em;
        }

        .main-nav {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .main-nav-btn {
            padding: 15px 30px;
            background: white;
            border: 3px solid #e2e8f0;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1.1em;
            font-weight: 700;
            transition: all 0.3s;
            color: #4a5568;
        }

        .main-nav-btn:hover {
            border-color: #667eea;
            color: #667eea;
            transform: translateY(-2px);
        }

        .main-nav-btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-color: #667eea;
        }

        .section {
            display: none;
        }

        .section.active {
            display: block;
            animation: fadeIn 0.4s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 25px;
        }

        .section-title {
            font-size: 2em;
            margin-bottom: 10px;
        }

        .section-desc {
            font-size: 1.1em;
            opacity: 0.95;
        }

        .part-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .part-tab {
            padding: 10px 20px;
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 600;
            transition: all 0.3s;
            color: #4a5568;
        }

        .part-tab:hover {
            border-color: #667eea;
            color: #667eea;
        }

        .part-tab.active {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

        .part-content {
            display: none;
        }

        .part-content.active {
            display: block;
        }

        .task {
            background: #f7fafc;
            padding: 25px;
            margin-bottom: 25px;
            border-radius: 12px;
            border-left: 5px solid #667eea;
        }

        .task-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .task-title {
            font-size: 1.3em;
            font-weight: 700;
            color: #2d3748;
        }

        .task-text {
            font-size: 1.1em;
            color: #4a5568;
            margin: 15px 0;
            line-height: 1.8;
        }

        .task-text.german {
            font-weight: 600;
            color: #2d3748;
        }

        .task-text.chinese {
            color: #666;
            display: none;
            margin-top: 10px;
            padding-top: 15px;
            border-top: 2px dashed #e2e8f0;
        }

        .task-text.chinese.show {
            display: block;
        }

        .options {
            margin: 15px 0;
        }

        .option {
            padding: 12px 20px;
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .option:hover {
            border-color: #667eea;
            background: #edf2f7;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 600;
            transition: all 0.3s;
            margin-right: 10px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background: white;
            color: #667eea;
            border: 2px solid #667eea;
        }

        .btn-secondary:hover {
            background: #667eea;
            color: white;
        }

        .email-box, .form-box {
            background: white;
            padding: 20px;
            border-radius: 8px;
            border: 2px solid #e2e8f0;
            margin: 15px 0;
            font-family: monospace;
            white-space: pre-wrap;
            line-height: 1.8;
        }

        .writing-instruction {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 15px;
            margin: 15px 0;
            border-radius: 4px;
        }

        .image-card {
            display: inline-block;
            width: 150px;
            height: 150px;
            background: #f7fafc;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            margin: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3em;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
        }

        table td, table th {
            border: 1px solid #e2e8f0;
            padding: 10px;
            text-align: left;
        }

        table th {
            background: #f7fafc;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎓 Goethe A1 完整考试练习</h1>
        <div class="subtitle">Start Deutsch 1 - 模拟试卷 Modellsatz</div>

        <div class="main-nav">
            <button class="main-nav-btn active" onclick="showSection('hoeren')">🎧 Hören 听力</button>
            <button class="main-nav-btn" onclick="showSection('lesen')">📖 Lesen 阅读</button>
            <button class="main-nav-btn" onclick="showSection('schreiben')">✍️ Schreiben 写作</button>
            <button class="main-nav-btn" onclick="showSection('sprechen')">💬 Sprechen 口语</button>
        </div>

        <!-- Hören Section -->
        <div id="hoeren" class="section active">
            <div class="section-header">
                <div class="section-title">🎧 Hören 听力</div>
                <div class="section-desc">circa 20 Minuten | 本测试包含3个部分，您将听到简短对话和通知</div>
            </div>
            <p style="text-align: center; margin-bottom: 20px;">
                <a href="listening-complete.html" class="btn btn-primary" style="text-decoration: none;">
                    📻 进入完整听力练习页面（17个题目）
                </a>
            </p>
            <p style="text-align: center; color: #666;">听力部分包含15个正式题目 + 2个示例，配有完整德语原文、中文翻译和音频播放功能</p>
        </div>

        <!-- Lesen Section -->
        <div id="lesen" class="section">
            <div class="section-header">
                <div class="section-title">📖 Lesen 阅读</div>
                <div class="section-desc">circa 25 Minuten | 本测试包含3个部分，阅读短信、广告等</div>
            </div>

            <div class="part-tabs">
                <button class="part-tab active" onclick="showLesenPart('lesen1')">Teil 1</button>
                <button class="part-tab" onclick="showLesenPart('lesen2')">Teil 2</button>
                <button class="part-tab" onclick="showLesenPart('lesen3')">Teil 3</button>
            </div>

            <!-- Teil 1 -->
            <div id="lesen1" class="part-content active">
                <h3 style="color: #667eea; margin-bottom: 20px;">Teil 1: Lesen Sie die beiden Texte und die Aufgaben 1 bis 5</h3>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Beispiel 示例</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_bsp')">显示翻译</button>
                    </div>
                    <div class="task-text german">Lis Zug kommt aus Hannover.</div>
                    <div id="lesen_bsp" class="task-text chinese">莉的火车来自汉诺威。</div>
                    <div class="email-box">Hallo Li,

danke für deine Mail. Dein Zug kommt hier in Hannover um 12.36 Uhr an. Ich bin ab 12.15 Uhr im Hauptbahnhof und warte auf dich vor der Auskunft.

Du kannst mich den ganzen Vormittag auf meinem Handy (++49 173 62 205 59) erreichen.

Deine
Karin</div>
                    <div class="options">
                        <div class="option">✓ Richtig 正确</div>
                        <div class="option">✗ Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 1</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_1')">显示翻译</button>
                    </div>
                    <div class="task-text german">Lis Zug kommt nach halb eins an.</div>
                    <div id="lesen_1" class="task-text chinese">莉的火车在12:30后到达。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 2</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_2')">显示翻译</button>
                    </div>
                    <div class="task-text german">Karin wartet den ganzen Vormittag vor der Auskunft.</div>
                    <div id="lesen_2" class="task-text chinese">卡琳整个上午都在问讯处前等候。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="email-box">Liebe Carmen,

am kommenden Sonntag habe ich Geburtstag. Ich möchte gerne mit dir feiern und lade dich herzlich zu meiner Party am Samstagabend ein.

Wir fangen um 21 Uhr an. Ist das okay für dich? Es werden viele Leute da sein, die du auch kennst. Kannst du vielleicht einen Salat mitbringen? Und vergiss bitte nicht einen Pullover oder eine Jacke! Wir wollen nämlich draußen im Garten feiern.

Ich freue mich sehr auf dich!

Bis zum Wochenende
Ralf</div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 3</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_3')">显示翻译</button>
                    </div>
                    <div class="task-text german">Ralf hatte am letzten Wochenende Geburtstag.</div>
                    <div id="lesen_3" class="task-text chinese">拉尔夫上周末过生日。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 4</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_4')">显示翻译</button>
                    </div>
                    <div class="task-text german">Ralf hat nur zwei oder drei Leute eingeladen.</div>
                    <div id="lesen_4" class="task-text chinese">拉尔夫只邀请了两三个人。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 5</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_5')">显示翻译</button>
                    </div>
                    <div class="task-text german">Die Party findet draußen statt.</div>
                    <div id="lesen_5" class="task-text chinese">派对在户外举行。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>
            </div>

            <!-- Teil 2 -->
            <div id="lesen2" class="part-content">
                <h3 style="color: #667eea; margin-bottom: 20px;">Teil 2: Lesen Sie die Texte und die Aufgaben 6 bis 10</h3>
                <p style="margin-bottom: 20px;"><strong>Wo finden Sie Informationen? Kreuzen Sie an: a oder b</strong></p>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 6</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_6')">显示翻译</button>
                    </div>
                    <div class="task-text german">Sie möchten mit dem Schiff auf dem Rhein fahren.</div>
                    <div id="lesen_6" class="task-text chinese">您想乘船在莱茵河上航行。</div>
                    <div class="options">
                        <div class="option"><strong>a</strong> www.schiff-ruedesheim.de</div>
                        <div class="option"><strong>b</strong> www.bingen-ruedesheimer.de</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 7</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_7')">显示翻译</button>
                    </div>
                    <div class="task-text german">Sie möchten Deutsch in Deutschland lernen.</div>
                    <div id="lesen_7" class="task-text chinese">您想在德国学德语。</div>
                    <div class="options">
                        <div class="option"><strong>a</strong> www.sprachenfuchs.de</div>
                        <div class="option"><strong>b</strong> www.eviva.com</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 8</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_8')">显示翻译</button>
                    </div>
                    <div class="task-text german">Sie möchten ein Zugticket im Internet kaufen.</div>
                    <div id="lesen_8" class="task-text chinese">您想在网上购买火车票。</div>
                    <div class="options">
                        <div class="option"><strong>a</strong> www.DER.com</div>
                        <div class="option"><strong>b</strong> www.RED.com</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 9</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_9')">显示翻译</button>
                    </div>
                    <div class="task-text german">Sie möchten Informationen über den Bodensee.</div>
                    <div id="lesen_9" class="task-text chinese">您想了解博登湖的信息。</div>
                    <div class="options">
                        <div class="option"><strong>a</strong> www.bodensee.de</div>
                        <div class="option"><strong>b</strong> www.rottenmeier.de</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 10</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_10')">显示翻译</button>
                    </div>
                    <div class="task-text german">Sie sind in Wiesbaden und möchten mit dem Zug am Mittag in Hamburg sein.</div>
                    <div id="lesen_10" class="task-text chinese">您在威斯巴登，想中午坐火车到汉堡。</div>

                    <p><strong>a</strong> 选项 a</p>
                    <table>
                        <tr>
                            <th>Bahnhof</th>
                            <th>Datum</th>
                            <th>Zeit</th>
                            <th>Dauer</th>
                            <th>Umsteigen</th>
                            <th>Angebot</th>
                        </tr>
                        <tr>
                            <td>ab Hamburg</td>
                            <td>17.02.</td>
                            <td>12.18</td>
                            <td>4:34</td>
                            <td>1</td>
                            <td>ICE, S</td>
                        </tr>
                        <tr>
                            <td>an Wiesbaden</td>
                            <td>17.02.</td>
                            <td>16.52</td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </table>

                    <p><strong>b</strong> 选项 b</p>
                    <table>
                        <tr>
                            <th>Bahnhof</th>
                            <th>Datum</th>
                            <th>Zeit</th>
                            <th>Dauer</th>
                            <th>Umsteigen</th>
                            <th>Angebot</th>
                        </tr>
                        <tr>
                            <td>ab Wiesbaden</td>
                            <td>17.02.</td>
                            <td>08.09</td>
                            <td>4:31</td>
                            <td>1</td>
                            <td>S, ICE</td>
                        </tr>
                        <tr>
                            <td>an Hamburg</td>
                            <td>17.02.</td>
                            <td>12.40</td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Teil 3 -->
            <div id="lesen3" class="part-content">
                <h3 style="color: #667eea; margin-bottom: 20px;">Teil 3: Lesen Sie die Texte und die Aufgaben 11 bis 15</h3>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 11: In der Sprachschule</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_11')">显示翻译</button>
                    </div>
                    <div class="form-box">SPRACHZENTRUM

Das Sprachzentrum ist umgezogen.
Sie finden uns jetzt in der
Beethovenstr. 23</div>
                    <div class="form-box" style="margin-top: 10px;">In der 10-Uhr-Pause
bekommen Sie an der
Rezeption ein
Frühstückspaket:
Belegte Brötchen und Getränke für
2 Euro.</div>
                    <div class="task-text german">In der Sprachschule können Sie etwas zu essen kaufen.</div>
                    <div id="lesen_11" class="task-text chinese">在语言学校您可以买到吃的东西。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 12: An der Post</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_12')">显示翻译</button>
                    </div>
                    <div class="form-box">Öffnungszeiten:

montags – freitags
8.00 – 12.00 und 13.00 – 18.00

samstags
8.00 – 12.00</div>
                    <div class="task-text german">Es ist Samstagnachmittag. Sie können auf der Post Briefmarken kaufen.</div>
                    <div id="lesen_12" class="task-text chinese">现在是星期六下午。您可以在邮局买邮票。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 13: Am Bahnhof</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_13')">显示翻译</button>
                    </div>
                    <div class="form-box">Auf dem gesamten
Bahnhof ist das
Rauchen verboten.</div>
                    <div class="task-text german">Sie können hier Zigaretten rauchen.</div>
                    <div id="lesen_13" class="task-text chinese">您可以在这里抽烟。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 14: Eingang Restaurant</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_14')">显示翻译</button>
                    </div>
                    <div class="form-box">Heute im Bavaria:

Bayerischer Abend
Brezeln, Weißwürste, Sauerkraut
Volksmusik, ab 20 Uhr Tanz</div>
                    <div class="task-text german">Heute Abend können Sie in diesem Restaurant tanzen.</div>
                    <div id="lesen_14" class="task-text chinese">今晚您可以在这家餐厅跳舞。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">Aufgabe 15: An der Haltestelle</div>
                        <button class="btn btn-secondary" onclick="toggleTranslation('lesen_15')">显示翻译</button>
                    </div>
                    <div class="form-box">In der Neujahrsnacht
Busverkehr bis 23.00 Uhr
und
von 1.00 Uhr bis 5.00 Uhr
alle 30 Minuten</div>
                    <div class="task-text german">Von 23 Uhr bis 1 Uhr fährt kein Bus.</div>
                    <div id="lesen_15" class="task-text chinese">从23点到1点没有公交车。</div>
                    <div class="options">
                        <div class="option">Richtig 正确</div>
                        <div class="option">Falsch 错误</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Schreiben Section -->
        <div id="schreiben" class="section">
            <div class="section-header">
                <div class="section-title">✍️ Schreiben 写作</div>
                <div class="section-desc">circa 20 Minuten | 本测试包含2个部分：填写表格和写短文</div>
            </div>

            <div class="part-tabs">
                <button class="part-tab active" onclick="showSchreibenPart('schreiben1')">Teil 1: 填表</button>
                <button class="part-tab" onclick="showSchreibenPart('schreiben2')">Teil 2: 写信</button>
            </div>

            <!-- Teil 1 -->
            <div id="schreiben1" class="part-content active">
                <h3 style="color: #667eea; margin-bottom: 20px;">Teil 1: 填写表格</h3>

                <div class="task">
                    <div class="task-header">
                        <div class="task-title">任务说明</div>
